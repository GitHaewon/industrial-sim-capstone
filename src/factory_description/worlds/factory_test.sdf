    <!-- Matching warehouse destinations for the three loaded boxes. -->
    <model name="warehouse_zones">
      <static>true</static>
      <link name="zones">
        <visual name="zone_a"><pose>-5.2 -7.1 0.018 0 0 0</pose><geometry><box><size>1.35 1.0 0.025</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
        <visual name="zone_b"><pose>0 -7.1 0.018 0 0 0</pose><geometry><box><size>1.35 1.0 0.025</size></box></geometry><material><diffuse>0.04 0.6 0.1 1</diffuse></material></visual>
        <visual name="zone_c"><pose>5.2 -7.1 0.018 0 0 0</pose><geometry><box><size>1.35 1.0 0.025</size></box></geometry><material><diffuse>0.03 0.22 0.78 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Performance-conscious Harmonic warehouse shell inspired by the
         Apache-2.0 Gazebo Jetty demo layout. -->
    <model name="warehouse_building">
      <static>true</static>
      <link name="shell">
        <collision name="west_wall_collision"><pose>-11 0 2.75 0 0 0</pose><geometry><box><size>0.22 17 5.5</size></box></geometry></collision>
        <collision name="east_wall_collision"><pose>11 0 2.75 0 0 0</pose><geometry><box><size>0.22 17 5.5</size></box></geometry></collision>
        <collision name="north_wall_collision"><pose>0 8.5 2.75 0 0 0</pose><geometry><box><size>22 0.22 5.5</size></box></geometry></collision>
        <collision name="south_wall_left_collision"><pose>-8.5 -8.5 2.75 0 0 0</pose><geometry><box><size>5 0.22 5.5</size></box></geometry></collision>
        <collision name="south_wall_right_collision"><pose>8.5 -8.5 2.75 0 0 0</pose><geometry><box><size>5 0.22 5.5</size></box></geometry></collision>
        <visual name="west_wall"><pose>-11 0 2.75 0 0 0</pose><geometry><box><size>0.22 17 5.5</size></box></geometry><material><diffuse>0.56 0.59 0.62 1</diffuse></material></visual>
        <visual name="east_wall"><pose>11 0 2.75 0 0 0</pose><geometry><box><size>0.22 17 5.5</size></box></geometry><material><diffuse>0.56 0.59 0.62 1</diffuse></material></visual>
        <visual name="north_wall"><pose>0 8.5 2.75 0 0 0</pose><geometry><box><size>22 0.22 5.5</size></box></geometry><material><diffuse>0.56 0.59 0.62 1</diffuse></material></visual>
        <visual name="south_wall_left"><pose>-8.5 -8.5 2.75 0 0 0</pose><geometry><box><size>5 0.22 5.5</size></box></geometry><material><diffuse>0.56 0.59 0.62 1</diffuse></material></visual>
        <visual name="south_wall_right"><pose>8.5 -8.5 2.75 0 0 0</pose><geometry><box><size>5 0.22 5.5</size></box></geometry><material><diffuse>0.56 0.59 0.62 1</diffuse></material></visual>

        <!-- Roof trusses leave the ceiling visually open and keep rendering light. -->
        <visual name="roof_beam_west"><pose>-7.5 0 5.55 0 0 0</pose><geometry><box><size>0.18 17 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_beam_mid_west"><pose>-2.5 0 5.55 0 0 0</pose><geometry><box><size>0.18 17 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_beam_mid_east"><pose>2.5 0 5.55 0 0 0</pose><geometry><box><size>0.18 17 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_beam_east"><pose>7.5 0 5.55 0 0 0</pose><geometry><box><size>0.18 17 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_cross_north"><pose>0 5.7 5.55 0 0 0</pose><geometry><box><size>22 0.18 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_cross_center"><pose>0 0 5.55 0 0 0</pose><geometry><box><size>22 0.18 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>
        <visual name="roof_cross_south"><pose>0 -5.7 5.55 0 0 0</pose><geometry><box><size>22 0.18 0.18</size></box></geometry><material><diffuse>0.08 0.09 0.1 1</diffuse></material></visual>

        <!-- Three loading-bay frames and blue roll-up doors. -->
        <visual name="dock_door_a"><pose>-5.2 -8.37 1.55 0 0 0</pose><geometry><box><size>3.0 0.12 3.1</size></box></geometry><material><diffuse>0.04 0.18 0.42 1</diffuse></material></visual>
        <visual name="dock_door_b"><pose>0 -8.37 1.55 0 0 0</pose><geometry><box><size>3.0 0.12 3.1</size></box></geometry><material><diffuse>0.04 0.18 0.42 1</diffuse></material></visual>
        <visual name="dock_door_c"><pose>5.2 -8.37 1.55 0 0 0</pose><geometry><box><size>3.0 0.12 3.1</size></box></geometry><material><diffuse>0.04 0.18 0.42 1</diffuse></material></visual>
        <visual name="dock_header_a"><pose>-5.2 -8.25 3.3 0 0 0</pose><geometry><box><size>3.4 0.28 0.28</size></box></geometry><material><diffuse>0.9 0.6 0.05 1</diffuse></material></visual>
        <visual name="dock_header_b"><pose>0 -8.25 3.3 0 0 0</pose><geometry><box><size>3.4 0.28 0.28</size></box></geometry><material><diffuse>0.9 0.6 0.05 1</diffuse></material></visual>
        <visual name="dock_header_c"><pose>5.2 -8.25 3.3 0 0 0</pose><geometry><box><size>3.4 0.28 0.28</size></box></geometry><material><diffuse>0.9 0.6 0.05 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Two pallet-rack aisles behind the active sorting cell. -->
    <model name="warehouse_racking">
      <static>true</static>
      <link name="racks">
        <collision name="rack_north_collision"><pose>0 6.4 1.65 0 0 0</pose><geometry><box><size>17.6 1.0 3.3</size></box></geometry></collision>
        <collision name="rack_south_collision"><pose>0 4.5 1.65 0 0 0</pose><geometry><box><size>17.6 1.0 3.3</size></box></geometry></collision>

        <!-- Uprights: north row. -->
