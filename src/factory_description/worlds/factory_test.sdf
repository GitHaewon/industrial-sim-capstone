<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="factory_test">
    <physics name="default_physics" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics"/>
    <plugin
      filename="gz-sim-user-commands-system"
      name="gz::sim::systems::UserCommands"/>
    <plugin
      filename="gz-sim-scene-broadcaster-system"
      name="gz::sim::systems::SceneBroadcaster"/>
    <plugin
      filename="gz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin
      filename="gz-sim-logical-camera-system"
      name="gz::sim::systems::LogicalCamera">
      <render_engine>ogre2</render_engine>
    </plugin>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- High-bay warehouse lighting. -->
    <light name="high_bay_north_west" type="point">
      <pose>-6 4 5.2 0 0 0</pose>
      <diffuse>0.85 0.9 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>18</range><constant>0.7</constant><linear>0.03</linear><quadratic>0.005</quadratic></attenuation>
      <cast_shadows>true</cast_shadows>
    </light>
    <light name="high_bay_north_east" type="point">
      <pose>6 4 5.2 0 0 0</pose>
      <diffuse>0.85 0.9 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>18</range><constant>0.7</constant><linear>0.03</linear><quadratic>0.005</quadratic></attenuation>
      <cast_shadows>true</cast_shadows>
    </light>
    <light name="high_bay_south_west" type="point">
      <pose>-6 -4 5.2 0 0 0</pose>
      <diffuse>0.85 0.9 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>18</range><constant>0.7</constant><linear>0.03</linear><quadratic>0.005</quadratic></attenuation>
      <cast_shadows>true</cast_shadows>
    </light>
    <light name="high_bay_south_east" type="point">
      <pose>6 -4 5.2 0 0 0</pose>
      <diffuse>0.85 0.9 1 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>18</range><constant>0.7</constant><linear>0.03</linear><quadratic>0.005</quadratic></attenuation>
      <cast_shadows>true</cast_shadows>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>24 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>24 20</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.28 0.3 0.32 1</ambient>
            <diffuse>0.38 0.4 0.42 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Long conveyor with frame, belt, rollers, rails, and support legs. -->
    <model name="sorting_conveyor">
      <static>true</static>
      <pose>-1 0 0 0 0 0</pose>
      <link name="conveyor">
        <collision name="belt_collision">
          <pose>0 0 0.76 0 0 0</pose>
          <geometry><box><size>7.5 1.25 0.12</size></box></geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.7</mu>
                <mu2>100</mu2>
                <fdir1>0 1 0</fdir1>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name="belt">
          <pose>0 0 0.76 0 0 0</pose>
          <geometry><box><size>7.5 1.25 0.12</size></box></geometry>
          <material>
            <ambient>0.035 0.055 0.075 1</ambient>
            <diffuse>0.055 0.09 0.12 1</diffuse>
            <specular>0.35 0.35 0.35 1</specular>
          </material>
        </visual>
        <visual name="left_rail">
          <pose>0 0.69 0.94 0 0 0</pose>
          <geometry><box><size>7.7 0.08 0.38</size></box></geometry>
          <material>
            <ambient>0.75 0.78 0.8 1</ambient>
            <diffuse>0.82 0.84 0.86 1</diffuse>
          </material>
        </visual>
        <visual name="right_rail">
          <pose>0 -0.69 0.94 0 0 0</pose>
          <geometry><box><size>7.7 0.08 0.38</size></box></geometry>
          <material>
            <ambient>0.75 0.78 0.8 1</ambient>
            <diffuse>0.82 0.84 0.86 1</diffuse>
          </material>
        </visual>
        <visual name="frame_left">
          <pose>0 0.57 0.58 0 0 0</pose>
          <geometry><box><size>7.6 0.12 0.24</size></box></geometry>
          <material>
            <ambient>0.18 0.21 0.24 1</ambient>
            <diffuse>0.25 0.29 0.32 1</diffuse>
          </material>
        </visual>
        <visual name="frame_right">
          <pose>0 -0.57 0.58 0 0 0</pose>
          <geometry><box><size>7.6 0.12 0.24</size></box></geometry>
          <material>
            <ambient>0.18 0.21 0.24 1</ambient>
            <diffuse>0.25 0.29 0.32 1</diffuse>
          </material>
        </visual>
        <visual name="front_roller">
          <pose>-3.69 0 0.76 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.11</radius><length>1.2</length></cylinder></geometry>
          <material><diffuse>0.8 0.48 0.08 1</diffuse></material>
        </visual>
        <visual name="rear_roller">
          <pose>3.69 0 0.76 1.5708 0 0</pose>
          <geometry><cylinder><radius>0.11</radius><length>1.2</length></cylinder></geometry>
          <material><diffuse>0.8 0.48 0.08 1</diffuse></material>
        </visual>
        <visual name="leg_1_left">
          <pose>-2.8 0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="leg_1_right">
          <pose>-2.8 -0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="leg_2_left">
          <pose>0 0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="leg_2_right">
          <pose>0 -0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="leg_3_left">
          <pose>2.8 0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="leg_3_right">
          <pose>2.8 -0.48 0.3 0 0 0</pose>
          <geometry><box><size>0.14 0.14 0.6</size></box></geometry>
          <material><diffuse>0.26 0.29 0.31 1</diffuse></material>
        </visual>
        <visual name="pickup_zone">
          <pose>2.25 0 0.825 0 0 0</pose>
          <geometry><box><size>0.7 1.12 0.01</size></box></geometry>
          <material>
            <ambient>0.95 0.62 0.05 0.75</ambient>
            <diffuse>1 0.66 0.05 0.75</diffuse>
          </material>
          <transparency>0.25</transparency>
        </visual>
      </link>
      <plugin
        filename="gz-sim-track-controller-system"
        name="gz::sim::systems::TrackController">
        <link>conveyor</link>
        <velocity_topic>/conveyor/track_cmd_vel</velocity_topic>
        <odometry_topic>/conveyor/odometry</odometry_topic>
        <odometry_publish_frequency>10</odometry_publish_frequency>
        <max_command_age>0.5</max_command_age>
        <min_velocity>-0.5</min_velocity>
        <max_velocity>0.5</max_velocity>
        <min_acceleration>-0.8</min_acceleration>
        <max_acceleration>0.8</max_acceleration>
      </plugin>
    </model>

    <!-- Three high-contrast workpieces for the first vision pipeline. -->
    <model name="item_a_red_cube">
      <pose>-3.3 0 0.96 0 0 0</pose>
      <link name="item">
        <inertial><mass>0.25</mass><inertia><ixx>0.0027</ixx><iyy>0.0027</iyy><izz>0.0027</izz></inertia></inertial>
        <collision name="collision"><geometry><box><size>0.32 0.32 0.32</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.32 0.32 0.32</size></box></geometry>
          <material><ambient>0.75 0.03 0.03 1</ambient><diffuse>0.95 0.04 0.04 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="item_b_green_cylinder">
      <pose>-2.1 0 0.96 0 0 0</pose>
      <link name="item">
        <inertial><mass>0.25</mass><inertia><ixx>0.0027</ixx><iyy>0.0027</iyy><izz>0.0027</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.18</radius><length>0.32</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.18</radius><length>0.32</length></cylinder></geometry>
          <material><ambient>0.03 0.55 0.08 1</ambient><diffuse>0.04 0.85 0.12 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="item_c_blue_hex">
      <pose>-0.9 0 0.96 0 0 0</pose>
      <link name="item">
        <inertial><mass>0.25</mass><inertia><ixx>0.0027</ixx><iyy>0.0027</iyy><izz>0.0027</izz></inertia></inertial>
        <collision name="collision"><geometry><cylinder><radius>0.2</radius><length>0.32</length></cylinder></geometry></collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.2</radius><length>0.32</length></cylinder></geometry>
          <material><ambient>0.02 0.18 0.75 1</ambient><diffuse>0.03 0.3 1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Two-axis SCARA arm with physical revolute and prismatic joints. -->
    <model name="sorting_arm">
      <pose>1.25 -1.5 0 0 0 0</pose>
      <self_collide>false</self_collide>

      <link name="base_link">
        <inertial>
          <mass>20</mass>
          <inertia><ixx>1</ixx><iyy>1</iyy><izz>1</izz></inertia>
        </inertial>
        <collision name="base_collision">
          <pose>0 0 0.2 0 0 0</pose>
          <geometry><cylinder><radius>0.42</radius><length>0.4</length></cylinder></geometry>
        </collision>
        <collision name="column_collision">
          <pose>0 0 0.9 0 0 0</pose>
          <geometry><cylinder><radius>0.18</radius><length>1.4</length></cylinder></geometry>
        </collision>
        <visual name="base">
          <pose>0 0 0.2 0 0 0</pose>
          <geometry><cylinder><radius>0.42</radius><length>0.4</length></cylinder></geometry>
          <material><diffuse>0.12 0.16 0.2 1</diffuse></material>
        </visual>
        <visual name="column">
          <pose>0 0 0.9 0 0 0</pose>
          <geometry><cylinder><radius>0.18</radius><length>1.4</length></cylinder></geometry>
          <material><diffuse>0.95 0.52 0.04 1</diffuse></material>
        </visual>
      </link>

      <joint name="yaw_joint" type="revolute">
        <pose relative_to="base_link">0 0 1.5 0 0 0</pose>
        <parent>base_link</parent>
        <child>boom_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-3.0</lower><upper>3.0</upper><effort>250</effort><velocity>1.2</velocity></limit>
          <dynamics><damping>2.0</damping></dynamics>
        </axis>
      </joint>
      <link name="boom_link">
        <pose relative_to="yaw_joint">0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0.75 0 0 0 0</pose>
          <mass>5</mass>
          <inertia><ixx>1</ixx><iyy>0.2</iyy><izz>1</izz></inertia>
        </inertial>
        <collision name="boom_collision">
          <pose>0 0.75 0 0 0 0</pose>
          <geometry><box><size>0.24 1.5 0.24</size></box></geometry>
        </collision>
        <visual name="boom">
          <pose>0 0.75 0 0 0 0</pose>
          <geometry><box><size>0.24 1.5 0.24</size></box></geometry>
          <material><diffuse>0.95 0.52 0.04 1</diffuse></material>
        </visual>
        <visual name="shoulder">
          <geometry><cylinder><radius>0.28</radius><length>0.28</length></cylinder></geometry>
          <material><diffuse>0.18 0.22 0.26 1</diffuse></material>
        </visual>
      </link>

      <joint name="lift_joint" type="prismatic">
        <pose relative_to="boom_link">0 1.5 0 0 0 0</pose>
        <parent>boom_link</parent>
        <child>carriage_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>0</lower><upper>0.6</upper><effort>250</effort><velocity>0.8</velocity></limit>
          <dynamics><damping>3.0</damping></dynamics>
        </axis>
      </joint>
      <link name="carriage_link">
        <pose relative_to="lift_joint">0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 -0.22 0 0 0</pose>
          <mass>2</mass>
          <inertia><ixx>0.08</ixx><iyy>0.08</iyy><izz>0.02</izz></inertia>
        </inertial>
        <collision name="tool_collision">
          <pose>0 0 -0.22 0 0 0</pose>
          <geometry><cylinder><radius>0.08</radius><length>0.45</length></cylinder></geometry>
        </collision>
        <visual name="wrist">
          <geometry><cylinder><radius>0.17</radius><length>0.18</length></cylinder></geometry>
          <material><diffuse>0.18 0.22 0.26 1</diffuse></material>
        </visual>
        <visual name="tool">
          <pose>0 0 -0.22 0 0 0</pose>
          <geometry><cylinder><radius>0.08</radius><length>0.45</length></cylinder></geometry>
          <material><diffuse>0.72 0.75 0.78 1</diffuse></material>
        </visual>
        <visual name="suction_cup">
          <pose>0 0 -0.48 0 0 0</pose>
          <geometry><cylinder><radius>0.17</radius><length>0.08</length></cylinder></geometry>
          <material><diffuse>0.04 0.04 0.04 1</diffuse></material>
        </visual>
      </link>

      <joint name="world_fixed" type="fixed">
        <parent>world</parent>
        <child>base_link</child>
      </joint>

      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>yaw_joint</joint_name>
        <topic>/arm/yaw_cmd</topic>
        <p_gain>80</p_gain><i_gain>0.5</i_gain><d_gain>8</d_gain>
        <cmd_min>-250</cmd_min><cmd_max>250</cmd_max>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>lift_joint</joint_name>
        <topic>/arm/lift_cmd</topic>
        <p_gain>1000</p_gain><i_gain>10</i_gain><d_gain>50</d_gain>
        <cmd_min>-250</cmd_min><cmd_max>250</cmd_max>
      </plugin>
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher"/>

      <plugin filename="gz-sim-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>carriage_link</parent_link>
        <child_model>item_a_red_cube</child_model>
        <child_link>item</child_link>
        <detach_topic>/arm/a_red_cube/detach</detach_topic>
        <attach_topic>/arm/a_red_cube/attach</attach_topic>
        <output_topic>/arm/a_red_cube/attached</output_topic>
      </plugin>
      <plugin filename="gz-sim-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>carriage_link</parent_link>
        <child_model>item_b_green_cylinder</child_model>
        <child_link>item</child_link>
        <detach_topic>/arm/b_green_cylinder/detach</detach_topic>
        <attach_topic>/arm/b_green_cylinder/attach</attach_topic>
        <output_topic>/arm/b_green_cylinder/attached</output_topic>
      </plugin>
      <plugin filename="gz-sim-detachable-joint-system"
              name="gz::sim::systems::DetachableJoint">
        <parent_link>carriage_link</parent_link>
        <child_model>item_c_blue_hex</child_model>
        <child_link>item</child_link>
        <detach_topic>/arm/c_blue_hex/detach</detach_topic>
        <attach_topic>/arm/c_blue_hex/attach</attach_topic>
        <output_topic>/arm/c_blue_hex/attached</output_topic>
      </plugin>
    </model>

    <!-- Overhead RGB-D camera: this sensor publishes Gazebo image/depth topics. -->
    <model name="overhead_rgbd_camera">
      <static>true</static>
      <pose>-0.5 0 4.2 0 0 0</pose>
      <link name="camera_link">
        <visual name="body">
          <geometry><box><size>0.42 0.3 0.2</size></box></geometry>
          <material><diffuse>0.08 0.1 0.12 1</diffuse></material>
        </visual>
        <visual name="lens">
          <pose>0 0 -0.13 0 0 0</pose>
          <geometry><cylinder><radius>0.09</radius><length>0.08</length></cylinder></geometry>
          <material><diffuse>0.02 0.12 0.25 1</diffuse></material>
        </visual>
        <sensor name="rgbd_camera" type="rgbd_camera">
          <pose>0 0 -0.15 0 1.5708 0</pose>
          <always_on>true</always_on>
          <update_rate>15</update_rate>
          <topic>/factory/camera</topic>
          <camera>
            <horizontal_fov>1.35</horizontal_fov>
            <image><width>640</width><height>480</height><format>R8G8B8</format></image>
            <clip><near>0.1</near><far>12</far></clip>
            <depth_camera><clip><near>0.1</near><far>12</far></clip></depth_camera>
          </camera>
        </sensor>
      </link>
    </model>
    <model name="camera_gantry">
      <static>true</static>
      <link name="gantry">
        <visual name="left_post">
          <pose>-0.5 1.4 2.1 0 0 0</pose>
          <geometry><box><size>0.12 0.12 4.2</size></box></geometry>
          <material><diffuse>0.22 0.25 0.28 1</diffuse></material>
        </visual>
        <visual name="right_post">
          <pose>-0.5 -1.4 2.1 0 0 0</pose>
          <geometry><box><size>0.12 0.12 4.2</size></box></geometry>
          <material><diffuse>0.22 0.25 0.28 1</diffuse></material>
        </visual>
        <visual name="crossbeam">
          <pose>-0.5 0 4.1 0 0 0</pose>
          <geometry><box><size>0.14 2.9 0.14</size></box></geometry>
          <material><diffuse>0.95 0.52 0.04 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Logical pickup sensor drives the physical conveyor stop condition. -->
    <model name="pickup_sensor">
      <static>true</static>
      <pose>1.25 0 2.15 0 0 0</pose>
      <link name="pickup_sensor_link">
        <sensor name="pickup_logical_camera" type="logical_camera">
          <pose>0 0 0 0 1.5708 0</pose>
          <update_rate>30</update_rate>
          <logical_camera>
            <near>0.3</near>
            <far>1.6</far>
            <horizontal_fov>0.8</horizontal_fov>
            <aspect_ratio>1.5</aspect_ratio>
          </logical_camera>
          <always_on>true</always_on>
          <visualize>false</visualize>
          <topic>/pickup/logical_camera</topic>
        </sensor>
      </link>
    </model>

    <!-- The sorting boxes are physical mobile carriers. -->
    <model name="bin_a_red">
      <pose>0.5 -2.95 0 0 0 3.14159</pose>
      <link name="bin">
        <inertial><mass>18</mass><inertia><ixx>1.5</ixx><iyy>1.5</iyy><izz>1.5</izz></inertia></inertial>
        <collision name="base_collision"><pose>0 0 0.23 0 0 0</pose><geometry><box><size>0.95 0.95 0.16</size></box></geometry></collision>
        <collision name="wall_1_collision"><pose>0 0.45 0.42 0 0 0</pose><geometry><box><size>0.95 0.08 0.8</size></box></geometry></collision>
        <collision name="wall_2_collision"><pose>0 -0.45 0.42 0 0 0</pose><geometry><box><size>0.95 0.08 0.8</size></box></geometry></collision>
        <collision name="wall_3_collision"><pose>0.45 0 0.42 0 0 0</pose><geometry><box><size>0.08 0.95 0.8</size></box></geometry></collision>
        <collision name="wall_4_collision"><pose>-0.45 0 0.42 0 0 0</pose><geometry><box><size>0.08 0.95 0.8</size></box></geometry></collision>
        <visual name="base"><pose>0 0 0.23 0 0 0</pose><geometry><box><size>0.95 0.95 0.16</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
        <visual name="wall_1"><pose>0 0.45 0.42 0 0 0</pose><geometry><box><size>0.95 0.08 0.8</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
        <visual name="wall_2"><pose>0 -0.45 0.42 0 0 0</pose><geometry><box><size>0.95 0.08 0.8</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
        <visual name="wall_3"><pose>0.45 0 0.42 0 0 0</pose><geometry><box><size>0.08 0.95 0.8</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
        <visual name="wall_4"><pose>-0.45 0 0.42 0 0 0</pose><geometry><box><size>0.08 0.95 0.8</size></box></geometry><material><diffuse>0.75 0.04 0.04 1</diffuse></material></visual>
