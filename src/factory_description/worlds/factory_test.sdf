    <!-- Kinematic obstacle used by the RViz/Nav2 avoidance demo. The
         dynamic_obstacle_demo node briefly moves this pallet near the B box
         route through /world/factory_test/set_pose so LiDAR and costmaps can
         show live obstacle marking, clearing, and replanning. -->
    <model name="moving_pallet_obstacle">
      <static>true</static>
      <pose>8.2 -5.95 0 0 0 0</pose>
      <link name="pallet">
        <collision name="body_collision">
          <pose>0 0 0.45 0 0 0</pose>
          <geometry><box><size>1.05 0.85 0.9</size></box></geometry>
